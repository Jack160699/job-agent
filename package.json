    "test:e2e:prod": "playwright test --config=playwright.config.ts",
    "test:e2e:rc": "playwright test --config=playwright.config.ts --retries=0",
    "verify:release": "npm run lint && npm run typecheck && npm run test:unit && npm run build",
    "typecheck": "tsc --noEmit",
    "browser-worker": "npx tsx browser-worker/index.ts",
    "browser-worker:bridge": "npx tsx browser-worker/automation/mcp-bridge-server.ts",
