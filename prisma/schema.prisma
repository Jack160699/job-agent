generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum JobSource {
  LINKEDIN
  WELLFOUND
  NAUKRI
  INDEED
  GREENHOUSE
  LEVER
  ASHBY
  WORKDAY
  UPSC
  ISRO
  NTPC
  BEL
  IOCL
  IBPS
  RAILWAYS
  SSC
  DRDO
  RBI
  COMPANY_PORTAL
  OTHER

  @@map("job_source")
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
  UNKNOWN

  @@map("work_mode")
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
  UNKNOWN

  @@map("employment_type")
}

enum ApplicationStatus {
  DISCOVERED
  ANALYZED
  MATCHED
  SKIPPED
  RESUME_GENERATED
  COVER_LETTER_GENERATED
  NEEDS_INFORMATION
  AWAITING_APPROVAL
  BLOCKED_CAPTCHA
  BLOCKED_LOGIN
  UNSUPPORTED
  EXPIRED
  PENDING_REVIEW
  SUBMITTING
  SUBMITTED
  FAILED
  WITHDRAWN
  INTERVIEWING
  OFFERED
  REJECTED
  ACCEPTED

  @@map("application_status")
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED

  @@map("interview_status")
}

enum EmailDirection {
  INBOUND
  OUTBOUND

  @@map("email_direction")
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  AUDIT

  @@map("log_level")
}

enum JobStatus {
  ACTIVE
  CLOSED
  EXPIRED
  ARCHIVED

  @@map("job_status")
}

enum UserPersona {
  JOB_SEEKER
  EMPLOYER
  RECRUITER
  AGENCY
  EXPLORER

  @@map("user_persona")
}

model User {
  id              String      @id @default(uuid()) @db.Uuid
  email           String      @unique
  fullName        String?     @map("full_name")
  avatarUrl       String?     @map("avatar_url")
  supabaseId      String?     @unique @map("supabase_id")
  persona         UserPersona @default(JOB_SEEKER)
  currentLocation String?     @map("current_location")
  linkedinUrl     String?     @map("linkedin_url")
  githubUrl       String?     @map("github_url")
  portfolioUrl    String?     @map("portfolio_url")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  masterResume             MasterResume?
  tailoredResumes          TailoredResume[]
  tailoredResumeVersions   TailoredResumeVersion[]
  coverLetters             CoverLetter[]
  jobs                     Job[]
  applications             Application[]
  recruiters               Recruiter[]
  interviews               Interview[]
  emails                   Email[]
  settings                 UserSettings?
  onboardingState          OnboardingState?
  hiringProfile            HiringProfile?
  preferenceHistory        PreferenceHistory[]
  consentRecords           ConsentRecord[]
  logs                     AuditLog[]
  secrets                  EncryptedSecret[]
  oauthStateNonces         OAuthStateNonce[]
  browserTasks             BrowserTask[]
  jobImports               JobImport[]
  jobFeedback              JobFeedback[]
  searchPlans              SearchPlan[]
  savedSearches            SavedSearch[]
  sourceHealth             JobSourceHealth[]
  jobProvenance            JobProvenance[]
  proactiveRecommendations ProactiveRecommendation[]
  consultantMessages       ConsultantMessage[]
  consultantConversations  ConsultantConversation[]
  agentActionProposals     AgentActionProposal[]
  subscription             Subscription?
  usageLedger              UsageLedger[]
  applicationScoreRecords  ApplicationScoreRecord[]

  @@map("users")
}

model MasterResume {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @map("user_id") @db.Uuid
  title      String   @default("Master Resume")
  content    Json
  rawText    String   @map("raw_text") @db.Text
  skills     String[]
  experience Json?
  education  Json?
  projects   Json?
  version    Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tailoredResumes TailoredResume[]
  versions        MasterResumeVersion[]

  @@map("master_resume")
}

model MasterResumeVersion {
  id             String   @id @default(uuid()) @db.Uuid
  masterResumeId String   @map("master_resume_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  version        Int
  title          String
  content        Json
  rawText        String   @map("raw_text") @db.Text
  skills         String[]
  createdAt      DateTime @default(now()) @map("created_at")

  masterResume MasterResume @relation(fields: [masterResumeId], references: [id], onDelete: Cascade)

  @@unique([masterResumeId, version])
  @@index([userId, createdAt])
  @@map("master_resume_versions")
}

model TailoredResume {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @map("user_id") @db.Uuid
  masterResumeId       String?   @map("master_resume_id") @db.Uuid
  jobId                String?   @map("job_id") @db.Uuid
  applicationId        String?   @unique @map("application_id") @db.Uuid
  title                String
  content              Json
  rawText              String    @map("raw_text") @db.Text
  matchScore           Float?    @map("match_score")
  highlights           String[]
  fileUrl              String?   @map("file_url")
  version              Int       @default(1)
  sourceMasterVersion  Int?      @map("source_master_version")
  sourceMasterTitle    String?   @map("source_master_title")
  sourceMasterSnapshot Json?     @map("source_master_snapshot")
  groundingReport      Json?     @map("grounding_report")
  archivedAt           DateTime? @map("archived_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  masterResume MasterResume?            @relation(fields: [masterResumeId], references: [id], onDelete: SetNull)
  job          Job?                     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  application  Application?             @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  versions     TailoredResumeVersion[]
  scoreRecords ApplicationScoreRecord[]

  @@index([userId])
  @@index([userId, archivedAt])
  @@index([jobId])
  @@map("tailored_resumes")
}

model TailoredResumeVersion {
  id                   String   @id @default(uuid()) @db.Uuid
  tailoredResumeId     String   @map("tailored_resume_id") @db.Uuid
  userId               String   @map("user_id") @db.Uuid
  version              Int
  title                String
  content              Json
  rawText              String   @map("raw_text") @db.Text
  highlights           String[]
  sourceMasterVersion  Int?     @map("source_master_version")
  sourceMasterTitle    String?  @map("source_master_title")
  sourceMasterSnapshot Json?    @map("source_master_snapshot")
  groundingReport      Json?    @map("grounding_report")
  createdAt            DateTime @default(now()) @map("created_at")

  tailoredResume TailoredResume @relation(fields: [tailoredResumeId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tailoredResumeId, version])
  @@index([userId, createdAt])
  @@map("tailored_resume_versions")
}

model CoverLetter {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  jobId         String?  @map("job_id") @db.Uuid
  applicationId String?  @unique @map("application_id") @db.Uuid
  title         String
  content       String   @db.Text
  tone          String   @default("professional")
  fileUrl       String?  @map("file_url")
  version       Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  job         Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([jobId])
  @@map("cover_letters")
}

model Job {
  id                     String         @id @default(uuid()) @db.Uuid
  userId                 String         @map("user_id") @db.Uuid
  externalId             String?        @map("external_id")
  source                 JobSource
  sourceUrl              String         @map("source_url")
  canonicalUrl           String?        @map("canonical_url")
  descriptionFingerprint String?        @map("description_fingerprint")
  title                  String
  company                String
  companySize            String?        @map("company_size")
  location               String?
  workMode               WorkMode       @default(UNKNOWN) @map("work_mode")
  employmentType         EmploymentType @default(UNKNOWN) @map("employment_type")
  salaryMin              Int?           @map("salary_min")
  salaryMax              Int?           @map("salary_max")
  salaryCurrency         String?        @default("USD") @map("salary_currency")
  visaSponsorship        Boolean?       @map("visa_sponsorship")
  description            String         @db.Text
  requiredSkills         String[]       @map("required_skills")
  preferredSkills        String[]       @map("preferred_skills")
  experienceMin          Int?           @map("experience_min")
  experienceMax          Int?           @map("experience_max")
  matchScore             Float?         @map("match_score")
  matchAnalysis          Json?          @map("match_analysis")
  status                 JobStatus      @default(ACTIVE)
  postedAt               DateTime?      @map("posted_at")
  closesAt               DateTime?      @map("closes_at")
  removedAt              DateTime?      @map("removed_at")
  savedAt                DateTime?      @map("saved_at")
  discoveredAt           DateTime       @default(now()) @map("discovered_at")
  analyzedAt             DateTime?      @map("analyzed_at")
  metadata               Json?
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications    Application[]
  tailoredResumes TailoredResume[]
  coverLetters    CoverLetter[]
  imports         JobImport[]
  feedback        JobFeedback[]
  provenance      JobProvenance[]
  scoreRecords    ApplicationScoreRecord[]

  @@unique([userId, source, externalId])
  @@index([userId, status])
  @@index([userId, matchScore])
  @@index([source])
  @@index([userId, canonicalUrl])
  @@index([userId, descriptionFingerprint])
  @@index([userId, savedAt])
  @@map("jobs")
}

model SearchPlan {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  version   String
  plan      Json
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("search_plans")
}

model SavedSearch {
  id                   String      @id @default(uuid()) @db.Uuid
  userId               String      @map("user_id") @db.Uuid
  name                 String
  titles               String[]
  locations            String[]
  sector               String
  governmentCategories String[]    @default([]) @map("government_categories")
  filters              Json
  searchStage          String      @default("strict") @map("search_stage")
  sources              JobSource[] @default([])
  alertFrequency       String      @default("OFF") @map("alert_frequency")
  alertsEnabled        Boolean     @default(false) @map("alerts_enabled")
  nextRunAt            DateTime?   @map("next_run_at")
  lastRunAt            DateTime?   @map("last_run_at")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([alertsEnabled, nextRunAt])
  @@index([userId, createdAt])
  @@map("saved_searches")
}

model JobSourceHealth {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  source              JobSource
  requests            Int       @default(0)
  successfulResponses Int       @default(0) @map("successful_responses")
  emptyResponses      Int       @default(0) @map("empty_responses")
  invalidJobs         Int       @default(0) @map("invalid_jobs")
  duplicateJobs       Int       @default(0) @map("duplicate_jobs")
  expiredJobs         Int       @default(0) @map("expired_jobs")
  failures            Int       @default(0)
  relevanceTotal      Float     @default(0) @map("relevance_total")
  relevanceSamples    Int       @default(0) @map("relevance_samples")
  consecutiveFailures Int       @default(0) @map("consecutive_failures")
  lastSuccessfulFetch DateTime? @map("last_successful_fetch")
  disabledUntil       DateTime? @map("disabled_until")
  lastError           String?   @map("last_error") @db.Text
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source])
  @@index([userId, disabledUntil])
  @@map("job_source_health")
}

model JobProvenance {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  jobId       String    @map("job_id") @db.Uuid
  source      JobSource
  sourceUrl   String    @map("source_url")
  externalId  String?   @map("external_id")
  firstSeenAt DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, source, sourceUrl])
  @@index([jobId])
  @@map("job_provenance")
}

model JobFeedback {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  relevant  Boolean
  reason    String?
  details   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, relevant, updatedAt])
  @@map("job_feedback")
}

model JobImport {
  id                String     @id @default(uuid()) @db.Uuid
  userId            String     @map("user_id") @db.Uuid
  jobId             String?    @map("job_id") @db.Uuid
  normalizedUrl     String     @map("normalized_url") @db.Text
  urlHash           String     @map("url_hash")
  source            JobSource?
  status            String     @default("pending")
  extractionMethod  String?    @map("extraction_method")
  extractorVersion  String     @default("v1") @map("extractor_version")
  extractedData     Json?      @map("extracted_data")
  manualDescription String?    @map("manual_description") @db.Text
  errorCode         String?    @map("error_code")
  errorMessage      String?    @map("error_message") @db.Text
  attempts          Int        @default(1)
  correctedAt       DateTime?  @map("corrected_at")
  completedAt       DateTime?  @map("completed_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([userId, urlHash])
  @@index([userId, status, createdAt])
  @@index([jobId])
  @@map("job_imports")
}

model Application {
  id             String            @id @default(uuid()) @db.Uuid
  userId         String            @map("user_id") @db.Uuid
  jobId          String            @map("job_id") @db.Uuid
  status         ApplicationStatus @default(DISCOVERED)
  matchScore     Float?            @map("match_score")
  autoSubmit     Boolean           @default(false) @map("auto_submit")
  requiresReview Boolean           @default(true) @map("requires_review")
  submittedAt    DateTime?         @map("submitted_at")
  formData       Json?             @map("form_data")
  documents      Json?
  notes          String?           @db.Text
  failureReason  String?           @map("failure_reason") @db.Text
  retryCount     Int               @default(0) @map("retry_count")
  lastAttemptAt  DateTime?         @map("last_attempt_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  job            Job                     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tailoredResume TailoredResume?
  coverLetter    CoverLetter?
  interviews     Interview[]
  emails         Email[]
  scoreRecord    ApplicationScoreRecord?

  @@unique([userId, jobId])
  @@index([userId, status])
  @@map("applications")
}

/// Phase D: exact before/after Kairela Job ATS Match scores, the exact
/// submitted resume document, and submission timestamp for one application.
/// Dedicated table rather than JSON piggybacked onto tailored_resumes so
/// this history is queryable and cannot be silently overwritten by
/// unrelated tailored-resume updates.
model ApplicationScoreRecord {
  id                        String    @id @default(uuid()) @db.Uuid
  userId                    String    @map("user_id") @db.Uuid
  applicationId             String    @unique @map("application_id") @db.Uuid
  jobId                     String    @map("job_id") @db.Uuid
  jobDescriptionFingerprint String?   @map("job_description_fingerprint")
  masterResumeVersion       Int       @map("master_resume_version")
  tailoredResumeId          String    @map("tailored_resume_id") @db.Uuid
  tailoredResumeVersion     Int       @map("tailored_resume_version")
  originalScore             Int       @map("original_score")
  originalBreakdown         Json      @map("original_breakdown")
  tailoredScore             Int       @map("tailored_score")
  tailoredBreakdown         Json      @map("tailored_breakdown")
  scoreDelta                Int       @map("score_delta")
  missingRequirements       String[]  @map("missing_requirements")
  groundingExclusions       Json?     @map("grounding_exclusions")
  submittedDocument         String?   @map("submitted_document") @db.Text
  submittedAt               DateTime? @map("submitted_at")
  generatedAt               DateTime  @default(now()) @map("generated_at")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  application    Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  job            Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tailoredResume TailoredResume @relation(fields: [tailoredResumeId], references: [id], onDelete: Cascade)

  @@index([userId, jobId])
  @@index([userId, createdAt])
  @@map("application_score_records")
}

model Recruiter {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  email       String?
  phone       String?
  company     String?
  linkedinUrl String?  @map("linkedin_url")
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails Email[]

  @@index([userId])
  @@map("recruiters")
}

model Interview {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String          @map("user_id") @db.Uuid
  applicationId String?         @map("application_id") @db.Uuid
  title         String
  company       String?
  status        InterviewStatus @default(SCHEDULED)
  scheduledAt   DateTime        @map("scheduled_at")
  durationMin   Int             @default(60) @map("duration_min")
  location      String?
  meetingUrl    String?         @map("meeting_url")
  calendarId    String?         @map("calendar_id")
  notes         String?         @db.Text
  feedback      String?         @db.Text
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId, scheduledAt])
  @@map("interviews")
}

model Email {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  applicationId String?        @map("application_id") @db.Uuid
  recruiterId   String?        @map("recruiter_id") @db.Uuid
  gmailId       String?        @map("gmail_id")
  threadId      String?        @map("thread_id")
  direction     EmailDirection
  fromAddress   String         @map("from_address")
  toAddress     String         @map("to_address")
  subject       String
  body          String         @db.Text
  isRead        Boolean        @default(false) @map("is_read")
  receivedAt    DateTime       @map("received_at")
  createdAt     DateTime       @default(now()) @map("created_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  recruiter   Recruiter?   @relation(fields: [recruiterId], references: [id], onDelete: SetNull)

  @@unique([userId, gmailId])
  @@index([userId, receivedAt])
  @@map("emails")
}

model UserSettings {
  id                               String           @id @default(uuid()) @db.Uuid
  userId                           String           @unique @map("user_id") @db.Uuid
  jobTitles                        String[]         @map("job_titles")
  experienceYears                  Int?             @map("experience_years")
  salaryMin                        Int?             @map("salary_min")
  salaryMax                        Int?             @map("salary_max")
  salaryCurrency                   String           @default("USD") @map("salary_currency")
  workModes                        WorkMode[]       @map("work_modes")
  locations                        String[]
  visaSponsorshipRequired          Boolean          @default(false) @map("visa_sponsorship_required")
  requiredSkills                   String[]         @map("required_skills")
  preferredSkills                  String[]         @map("preferred_skills")
  companySizes                     String[]         @map("company_sizes")
  employmentTypes                  EmploymentType[] @map("employment_types")
  matchThreshold                   Float            @default(70) @map("match_threshold")
  autoSubmitEnabled                Boolean          @default(false) @map("auto_submit_enabled")
  autoSubmitSources                JobSource[]      @map("auto_submit_sources")
  requireReview                    Boolean          @default(true) @map("require_review")
  enabledSources                   JobSource[]      @map("enabled_sources")
  searchFrequencyHours             Int              @default(6) @map("search_frequency_hours")
  notificationsEnabled             Boolean          @default(true) @map("notifications_enabled")
  sheetsSyncEnabled                Boolean          @default(false) @map("sheets_sync_enabled")
  sheetsId                         String?          @map("sheets_id")
  calendarSyncEnabled              Boolean          @default(false) @map("calendar_sync_enabled")
  gmailSyncEnabled                 Boolean          @default(false) @map("gmail_sync_enabled")
  driveFolderId                    String?          @map("drive_folder_id")
  targetCompanies                  String[]         @default([]) @map("target_companies")
  excludedCompanies                String[]         @default([]) @map("excluded_companies")
  industries                       String[]         @default([])
  willingToRelocate                Boolean          @default(false) @map("willing_to_relocate")
  noticePeriodDays                 Int?             @map("notice_period_days")
  currentRole                      String?          @map("profile_current_role")
  currentSalary                    Int?             @map("current_salary")
  workAuthorization                String?          @map("work_authorization")
  travelWillingness                String?          @map("travel_willingness")
  sectorPreference                 String           @default("PRIVATE") @map("sector_preference")
  governmentCategories             String[]         @default([]) @map("government_categories")
  preferencesComplete              Boolean          @default(false) @map("preferences_complete")
  driveBackupEnabled               Boolean          @default(false) @map("drive_backup_enabled")
  onboardingCompletedAt            DateTime?        @map("onboarding_completed_at")
  quietHoursStart                  String?          @map("quiet_hours_start")
  quietHoursEnd                    String?          @map("quiet_hours_end")
  proactiveFrequencyHours          Int              @default(24) @map("proactive_frequency_hours")
  disabledRecommendationCategories String[]         @default([]) @map("disabled_recommendation_categories")
  dailyDigestEnabled               Boolean          @default(false) @map("daily_digest_enabled")
  weeklyReportEnabled              Boolean          @default(true) @map("weekly_report_enabled")
