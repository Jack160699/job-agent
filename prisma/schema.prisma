generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum JobSource {
  LINKEDIN
  WELLFOUND
  NAUKRI
  INDEED
  GREENHOUSE
  LEVER
  ASHBY
  WORKDAY
  COMPANY_PORTAL
  OTHER

  @@map("job_source")
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
  UNKNOWN

  @@map("work_mode")
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
  UNKNOWN

  @@map("employment_type")
}

enum ApplicationStatus {
  DISCOVERED
  ANALYZED
  MATCHED
  SKIPPED
  RESUME_GENERATED
  COVER_LETTER_GENERATED
  PENDING_REVIEW
  SUBMITTING
  SUBMITTED
  FAILED
  WITHDRAWN
  INTERVIEWING
  OFFERED
  REJECTED
  ACCEPTED

  @@map("application_status")
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED

  @@map("interview_status")
}

enum EmailDirection {
  INBOUND
  OUTBOUND

  @@map("email_direction")
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  AUDIT

  @@map("log_level")
}

enum JobStatus {
  ACTIVE
  CLOSED
  EXPIRED
  ARCHIVED

  @@map("job_status")
}

enum UserPersona {
  JOB_SEEKER
  EMPLOYER
  RECRUITER
  AGENCY
  EXPLORER

  @@map("user_persona")
}

model User {
  id              String       @id @default(uuid()) @db.Uuid
  email           String       @unique
  fullName        String?      @map("full_name")
  avatarUrl       String?      @map("avatar_url")
  supabaseId      String?      @unique @map("supabase_id")
  persona         UserPersona  @default(JOB_SEEKER)
  currentLocation String?      @map("current_location")
  linkedinUrl     String?      @map("linkedin_url")
  githubUrl       String?      @map("github_url")
  portfolioUrl    String?      @map("portfolio_url")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  masterResume      MasterResume?
  tailoredResumes   TailoredResume[]
  coverLetters      CoverLetter[]
  jobs              Job[]
  applications      Application[]
  recruiters        Recruiter[]
  interviews        Interview[]
  emails            Email[]
  settings          UserSettings?
  onboardingState   OnboardingState?
  hiringProfile     HiringProfile?
  preferenceHistory PreferenceHistory[]
  consentRecords    ConsentRecord[]
  logs              AuditLog[]
  secrets           EncryptedSecret[]
  browserTasks      BrowserTask[]
  jobImports        JobImport[]
  jobFeedback       JobFeedback[]
  proactiveRecommendations ProactiveRecommendation[]
  consultantMessages ConsultantMessage[]
  subscription      Subscription?
  usageLedger       UsageLedger[]

  @@map("users")
}

model MasterResume {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  title       String   @default("Master Resume")
  content     Json
  rawText     String   @map("raw_text") @db.Text
  skills      String[]
  experience  Json?
  education   Json?
  projects    Json?
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tailoredResumes TailoredResume[]

  @@map("master_resume")
}

model TailoredResume {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  masterResumeId String   @map("master_resume_id") @db.Uuid
  jobId          String?  @map("job_id") @db.Uuid
  applicationId  String?  @unique @map("application_id") @db.Uuid
  title          String
  content        Json
  rawText        String   @map("raw_text") @db.Text
  matchScore     Float?   @map("match_score")
  highlights     String[]
  fileUrl        String?  @map("file_url")
  version        Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  masterResume MasterResume  @relation(fields: [masterResumeId], references: [id], onDelete: Cascade)
  job          Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  application  Application?  @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([jobId])
  @@map("tailored_resumes")
}

model CoverLetter {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  jobId         String?  @map("job_id") @db.Uuid
  applicationId String?  @unique @map("application_id") @db.Uuid
  title         String
  content       String   @db.Text
  tone          String   @default("professional")
  fileUrl       String?  @map("file_url")
  version       Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  job         Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([jobId])
  @@map("cover_letters")
}

model Job {
  id              String         @id @default(uuid()) @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  externalId      String?        @map("external_id")
  source          JobSource
  sourceUrl       String         @map("source_url")
  title           String
  company         String
  companySize     String?        @map("company_size")
  location        String?
  workMode        WorkMode       @default(UNKNOWN) @map("work_mode")
  employmentType  EmploymentType @default(UNKNOWN) @map("employment_type")
  salaryMin       Int?           @map("salary_min")
  salaryMax       Int?           @map("salary_max")
  salaryCurrency  String?        @default("USD") @map("salary_currency")
  visaSponsorship Boolean?       @map("visa_sponsorship")
  description     String         @db.Text
  requiredSkills  String[]       @map("required_skills")
  preferredSkills String[]       @map("preferred_skills")
  experienceMin   Int?           @map("experience_min")
  experienceMax   Int?           @map("experience_max")
  matchScore      Float?         @map("match_score")
  matchAnalysis   Json?          @map("match_analysis")
  status          JobStatus      @default(ACTIVE)
  postedAt        DateTime?      @map("posted_at")
  discoveredAt    DateTime       @default(now()) @map("discovered_at")
  analyzedAt      DateTime?      @map("analyzed_at")
  metadata        Json?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications    Application[]
  tailoredResumes TailoredResume[]
  coverLetters    CoverLetter[]
  imports         JobImport[]
  feedback        JobFeedback[]

  @@unique([userId, source, externalId])
  @@index([userId, status])
  @@index([userId, matchScore])
  @@index([source])
  @@map("jobs")
}

model JobFeedback {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  relevant  Boolean
  reason    String?
  details   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, relevant, updatedAt])
  @@map("job_feedback")
}

model JobImport {
  id                String     @id @default(uuid()) @db.Uuid
  userId            String     @map("user_id") @db.Uuid
  jobId             String?    @map("job_id") @db.Uuid
  normalizedUrl     String     @map("normalized_url") @db.Text
  urlHash           String     @map("url_hash")
  source            JobSource?
  status            String     @default("pending")
  extractionMethod  String?    @map("extraction_method")
  extractorVersion  String     @default("v1") @map("extractor_version")
  extractedData     Json?      @map("extracted_data")
  manualDescription String?    @map("manual_description") @db.Text
  errorCode         String?    @map("error_code")
  errorMessage      String?    @map("error_message") @db.Text
  attempts          Int        @default(1)
  correctedAt       DateTime?  @map("corrected_at")
  completedAt       DateTime?  @map("completed_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([userId, urlHash])
  @@index([userId, status, createdAt])
  @@index([jobId])
  @@map("job_imports")
}

model Application {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @map("user_id") @db.Uuid
  jobId           String            @map("job_id") @db.Uuid
  status          ApplicationStatus @default(DISCOVERED)
  matchScore      Float?            @map("match_score")
  autoSubmit      Boolean           @default(false) @map("auto_submit")
  requiresReview  Boolean           @default(true) @map("requires_review")
  submittedAt     DateTime?         @map("submitted_at")
  formData        Json?             @map("form_data")
  documents       Json?
  notes           String?           @db.Text
  failureReason   String?           @map("failure_reason") @db.Text
  retryCount      Int               @default(0) @map("retry_count")
  lastAttemptAt   DateTime?         @map("last_attempt_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  job           Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tailoredResume TailoredResume?
  coverLetter   CoverLetter?
  interviews    Interview[]
  emails        Email[]

  @@unique([userId, jobId])
  @@index([userId, status])
  @@map("applications")
}

model Recruiter {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  email       String?
  phone       String?
  company     String?
  linkedinUrl String?  @map("linkedin_url")
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails Email[]

  @@index([userId])
  @@map("recruiters")
}

model Interview {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String          @map("user_id") @db.Uuid
  applicationId String?         @map("application_id") @db.Uuid
  title         String
  company       String?
  status        InterviewStatus @default(SCHEDULED)
  scheduledAt   DateTime        @map("scheduled_at")
  durationMin   Int             @default(60) @map("duration_min")
  location      String?
  meetingUrl    String?         @map("meeting_url")
  calendarId    String?         @map("calendar_id")
  notes         String?         @db.Text
  feedback      String?         @db.Text
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId, scheduledAt])
  @@map("interviews")
}

model Email {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  applicationId String?        @map("application_id") @db.Uuid
  recruiterId   String?        @map("recruiter_id") @db.Uuid
  gmailId       String?        @unique @map("gmail_id")
  threadId      String?        @map("thread_id")
  direction     EmailDirection
  fromAddress   String         @map("from_address")
  toAddress     String         @map("to_address")
  subject       String
  body          String         @db.Text
  isRead        Boolean        @default(false) @map("is_read")
  receivedAt    DateTime       @map("received_at")
  createdAt     DateTime       @default(now()) @map("created_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  recruiter   Recruiter?   @relation(fields: [recruiterId], references: [id], onDelete: SetNull)

  @@index([userId, receivedAt])
  @@map("emails")
}

model UserSettings {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  jobTitles             String[] @map("job_titles")
  experienceYears       Int?     @map("experience_years")
  salaryMin             Int?     @map("salary_min")
  salaryMax             Int?     @map("salary_max")
  salaryCurrency        String   @default("USD") @map("salary_currency")
  workModes             WorkMode[] @map("work_modes")
  locations             String[]
  visaSponsorshipRequired Boolean @default(false) @map("visa_sponsorship_required")
  requiredSkills        String[] @map("required_skills")
  preferredSkills       String[] @map("preferred_skills")
  companySizes          String[] @map("company_sizes")
  employmentTypes       EmploymentType[] @map("employment_types")
  matchThreshold        Float    @default(70) @map("match_threshold")
  autoSubmitEnabled     Boolean  @default(false) @map("auto_submit_enabled")
  autoSubmitSources     JobSource[] @map("auto_submit_sources")
  requireReview         Boolean  @default(true) @map("require_review")
  enabledSources        JobSource[] @map("enabled_sources")
  searchFrequencyHours  Int      @default(6) @map("search_frequency_hours")
  notificationsEnabled  Boolean  @default(true) @map("notifications_enabled")
  sheetsSyncEnabled     Boolean  @default(false) @map("sheets_sync_enabled")
  sheetsId              String?  @map("sheets_id")
  calendarSyncEnabled   Boolean  @default(false) @map("calendar_sync_enabled")
  gmailSyncEnabled      Boolean  @default(false) @map("gmail_sync_enabled")
  driveFolderId         String?  @map("drive_folder_id")
  targetCompanies       String[] @default([]) @map("target_companies")
  excludedCompanies     String[] @default([]) @map("excluded_companies")
  industries            String[] @default([])
  willingToRelocate     Boolean  @default(false) @map("willing_to_relocate")
  noticePeriodDays      Int?     @map("notice_period_days")
  currentRole           String?  @map("profile_current_role")
  currentSalary         Int?     @map("current_salary")
  preferencesComplete   Boolean  @default(false) @map("preferences_complete")
  driveBackupEnabled    Boolean  @default(false) @map("drive_backup_enabled")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  quietHoursStart       String?   @map("quiet_hours_start")
  quietHoursEnd         String?   @map("quiet_hours_end")
  proactiveFrequencyHours Int     @default(24) @map("proactive_frequency_hours")
  disabledRecommendationCategories String[] @default([]) @map("disabled_recommendation_categories")
  dailyDigestEnabled    Boolean  @default(false) @map("daily_digest_enabled")
  weeklyReportEnabled   Boolean  @default(true) @map("weekly_report_enabled")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("settings")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  level      LogLevel @default(INFO)
  action     String
  resource   String?
  resourceId String?  @map("resource_id")
  message    String   @db.Text
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([level, createdAt])
  @@map("logs")
}

model EncryptedSecret {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("encrypted_secrets")
}

model BackgroundJob {
  id              String    @id @default(uuid()) @db.Uuid
  type            String
  payload         Json?
  status          String    @default("pending")
  priority        Int       @default(0)
  source          String    @default("scheduled")
  userId          String?   @map("user_id") @db.Uuid
  attempts        Int       @default(0)
  maxAttempts     Int       @default(3) @map("max_attempts")
  error           String?   @db.Text
  scheduledAt     DateTime  @default(now()) @map("scheduled_at")
  queuedAt        DateTime  @default(now()) @map("queued_at")
  claimedAt       DateTime? @map("claimed_at")
  startedAt       DateTime? @map("started_at")
  heartbeatAt     DateTime? @map("heartbeat_at")
  completedAt     DateTime? @map("completed_at")
  failedAt        DateTime? @map("failed_at")
  cancelledAt     DateTime? @map("cancelled_at")
  progressStage   String?   @map("progress_stage")
  progressPercent Int       @default(0) @map("progress_percent")
  progressMeta    Json?     @map("progress_meta")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([status, priority, scheduledAt])
  @@index([type])
  @@index([userId, type, status])
  @@map("background_jobs")
}

model BrowserTask {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  applicationId   String?   @map("application_id") @db.Uuid
  type            String
  platform        String?
  status          String    @default("pending")
  progress        Int       @default(0)
  payload         Json?
  result          Json?
  error           String?   @db.Text
  screenshotPaths String[]  @default([]) @map("screenshot_paths")
  attempts        Int       @default(0)
  maxAttempts     Int       @default(3) @map("max_attempts")
  cancelledAt     DateTime? @map("cancelled_at")
  scheduledAt     DateTime  @default(now()) @map("scheduled_at")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([userId, status])
  @@index([userId, applicationId, type, status])
  @@map("browser_tasks")
}

model OnboardingState {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  currentStep     String    @default("welcome") @map("current_step")
  completedSteps  String[]  @default([]) @map("completed_steps")
  draftData       Json?     @map("draft_data")
  isComplete      Boolean   @default(false) @map("is_complete")
  completionPct   Int       @default(0) @map("completion_pct")
  completedAt     DateTime? @map("completed_at")
  version         Int       @default(1)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_state")
}

model HiringProfile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  companyName       String?  @map("company_name")
  companySize       String?  @map("company_size")
  hiringGoal        String?  @map("hiring_goal")
  userRole          String?  @map("user_role")
  rolesHired        String[] @default([]) @map("roles_hired")
  hiringVolume      String?  @map("hiring_volume")
  locations         String[] @default([])
  teamMembers       Int?     @map("team_members")
  preferredSources  String[] @default([]) @map("preferred_sources")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("hiring_profiles")
}

model PreferenceHistory {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  version       Int
  snapshot      Json
  changedFields String[] @default([]) @map("changed_fields")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, version])
  @@map("preference_history")
}

model ConsentRecord {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  consentType String   @map("consent_type")
  granted     Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType])
  @@map("consent_records")
}

model ProactiveRecommendation {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  type        String
  category    String    @default("career")
  priority    String    @default("medium")
  title       String
  body        String    @db.Text
  reason      String    @db.Text
  evidence    Json?
  suggestedAction String? @map("suggested_action") @db.Text
  actionUrl   String?   @map("action_url")
  status      String    @default("active")
  dismissed   Boolean   @default(false)
  snoozedUntil DateTime? @map("snoozed_until")
  completedAt DateTime? @map("completed_at")
  expiresAt   DateTime? @map("expires_at")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dismissed, createdAt])
  @@index([userId, category, status])
  @@index([expiresAt])
  @@map("proactive_recommendations")
}

model ConsultantMessage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String
  content   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("consultant_messages")
}

enum SubscriptionPlan {
  FREE
  PRO
  TEAM

  @@map("subscription_plan")
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED

  @@map("subscription_status")
}

model Subscription {
  id              String             @id @default(uuid()) @db.Uuid
  userId          String             @unique @map("user_id") @db.Uuid
  plan            SubscriptionPlan   @default(FREE)
  status          SubscriptionStatus @default(ACTIVE)
  stripeCustomerId String?           @map("stripe_customer_id")
  stripeSubscriptionId String?       @map("stripe_subscription_id")
  currentPeriodEnd DateTime?         @map("current_period_end")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model UsageLedger {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  feature   String
  quantity  Int      @default(1)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, feature, createdAt])
  @@map("usage_ledger")
