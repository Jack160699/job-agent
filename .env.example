# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Encryption (32-byte hex key for secrets)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Cron secret for background jobs
CRON_SECRET=your-cron-secret

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Google OAuth (optional integrations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# Job search board slugs (comma-separated)
JOB_SEARCH_GREENHOUSE_BOARDS=openai,stripe
JOB_SEARCH_LEVER_COMPANIES=netflix
JOB_SEARCH_ASHBY_BOARDS=linear
JOB_SEARCH_WORKDAY_COMPANIES=

# Browser automation (Playwright local, MCP bridge for remote)
BROWSER_HEADLESS=true
BROWSER_MCP_BRIDGE_URL=
BROWSER_MCP_PORT=3847
BROWSER_WORKER_TOKEN=
BROWSER_WORKER_MODE=all
BROWSER_QUEUE_ENABLED=false

# Vercel
VERCEL_URL=
